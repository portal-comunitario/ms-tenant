spring.application.name=ms-tenant
server.port=8082

spring.datasource.url=jdbc:postgresql://localhost:5432/portalcomunitario
spring.datasource.username=postgres
spring.datasource.password=CAMBIAR_PASSWORD
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=true

spring.flyway.enabled=true
spring.flyway.baseline-on-migrate=true
spring.flyway.baseline-version=0
# Historial Flyway propio (public es compartido con ms-auth)
spring.flyway.table=flyway_schema_history_tenant

# DEBE coincidir EXACTO con el app.jwt.secret de ms-auth/ms-community (HS512)
app.jwt.secret=CAMBIAR_JWT_SECRET_HS512
app.jwt.expiration=86400000

# Login de plataforma (super-admin municipalidad) — credencial sembrada (demo)
app.platform.email=comunidades@maipu.cl
app.platform.password=admin123

# Token interno servicio-a-servicio + URLs para provisioning (MT2)
app.internal.token=portal-internal-2026
app.services.auth-url=http://localhost:8081
app.services.community-url=http://localhost:8084
